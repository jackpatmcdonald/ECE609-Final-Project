<!-- potential_field.launch
     Launches the full potential field replanning pipeline:
       1. Gazebo + TurtleBot3 Waffle Pi
       2. Obstacle spawner
       3. Obstacle sensor (laser clustering)
       4. Potential field planner
       5. Metrics recorder
-->
<launch>
  <!-- ── Config args ──────────────────────────────────────────────────── -->
  <arg name="goal_x"          default="10.0"/>
  <arg name="goal_y"          default="0.0"/>
  <arg name="density"         default="medium"/>   <!-- low | medium | high -->
  <arg name="obstacle_speed"  default="0.3"/>
  <arg name="trial"           default="0"/>

  <!-- ── TurtleBot3 model ─────────────────────────────────────────────── -->
  <env name="TURTLEBOT3_MODEL" value="waffle_pi"/>

  <!-- ── Gazebo (empty world) ─────────────────────────────────────────── -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name"   value="$(find obstacle_avoidance)/worlds/warehouse.world"/>
    <arg name="paused"       value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui"          value="true"/>
  </include>

  <!-- ── Spawn TurtleBot3 ─────────────────────────────────────────────── -->
  <include file="$(find turtlebot3_gazebo)/launch/put_robot_in_world.launch">
    <arg name="x_pos" value="0.0"/>
    <arg name="y_pos" value="0.0"/>
    <arg name="z_pos" value="0.0"/>
  </include>

  <!-- ── Obstacle spawner ─────────────────────────────────────────────── -->
  <node pkg="obstacle_avoidance" type="obstacle_spawner.py" name="obstacle_spawner" output="screen">
    <param name="density"        value="$(arg density)"/>
    <param name="obstacle_speed" value="$(arg obstacle_speed)"/>
  </node>

  <!-- ── Obstacle sensor ──────────────────────────────────────────────── -->
  <node pkg="obstacle_avoidance" type="obstacle_sensor.py" name="obstacle_sensor" output="screen"/>

  <!-- ── Potential field planner ──────────────────────────────────────── -->
  <node pkg="obstacle_avoidance" type="potential_field_planner.py" name="planner" output="screen">
    <param name="goal_x" value="$(arg goal_x)"/>
    <param name="goal_y" value="$(arg goal_y)"/>
    <!-- shelf waypoints: N2 rack (2.5, 2.8) then S2 rack (2.5, -2.8) -->
    <rosparam param="waypoints">[2.5, 2.8, 2.5, -2.8]</rosparam>
  </node>

  <!-- ── Metrics recorder ─────────────────────────────────────────────── -->
  <node pkg="obstacle_avoidance" type="metrics_recorder.py" name="metrics_recorder" output="screen">
    <param name="strategy" value="potential_field"/>
    <param name="density"  value="$(arg density)"/>
    <param name="trial"    value="$(arg trial)"/>
  </node>

  <!-- ── RViz ─────────────────────────────────────────────────────────── -->
  <node pkg="rviz" type="rviz" name="rviz"
        args="-d $(find obstacle_avoidance)/config/rviz_config.rviz"
        required="false"/>
</launch>
